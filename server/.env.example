PORT=5000
MONGODB_URI=mongodb://localhost:27017/petvault
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRES_IN=3d

MAX_FILE_SIZE=5000000
UPLOAD_PATH=./uploads

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

SERVER_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173
BASE_URL=http://localhost:5000

EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-password

RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

BOOKING_WINDOW_DAYS=7
AUTO_CANCEL_GRACE_MINUTES=1
AUTO_CANCEL_REASON=No response from provider
AUTO_CANCEL_CHECK_INTERVAL_MINUTES=1
REMINDER_RUN_INTERVAL_HOURS=6
ENABLE_REMINDER_SCHEDULER=true

HIGH_VALUE_TRANSACTION_THRESHOLD=50000
MIN_PAYOUT_AMOUNT=100
MAX_PAYOUT_AMOUNT=
